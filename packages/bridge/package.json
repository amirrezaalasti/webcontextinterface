{
  "name": "@webcontextinterface/bridge",
  "version": "1.2.0",
  "description": "WCI bridge — typed action dispatch and ActionResult protocol",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amirrezaalasti/webcontextinterface.git",
    "directory": "packages/bridge"
  },
  "homepage": "https://webcontextinterface.vercel.app/",
  "bugs": {
    "url": "https://github.com/amirrezaalasti/webcontextinterface/issues"
  },
  "dependencies": {
    "@webcontextinterface/context": "^1.2.0",
    "@webcontextinterface/spec": "^1.2.0"
  },
  "keywords": ["wci", "bridge", "actions", "automation", "llm", "web-context-interface"]
}
