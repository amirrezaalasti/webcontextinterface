{
  "name": "@wci/core",
  "version": "1.0.0",
  "description": "Web Context Interface (WCI) — complete SDK: spec, distiller, bridge, and site context",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@wci/spec": "*",
    "@wci/distiller": "*",
    "@wci/bridge": "*",
    "@wci/context": "*"
  },
  "keywords": ["wci", "llm", "agents", "dom", "accessibility", "sdk"],
  "repository": {
    "type": "git",
    "url": "https://github.com/wci/wci"
  }
}
