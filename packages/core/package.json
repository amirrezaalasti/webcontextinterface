{
  "name": "@webcontextinterface/core",
  "version": "1.0.0",
  "description": "Web Context Interface (WCI) — complete SDK: spec, distiller, bridge, and site context",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amirrezaalasti/webcontextinterface.git",
    "directory": "packages/core"
  },
  "homepage": "https://webcontextinterface.vercel.app/",
  "bugs": {
    "url": "https://github.com/amirrezaalasti/webcontextinterface/issues"
  },
  "dependencies": {
    "@webcontextinterface/spec": "^1.0.0",
    "@webcontextinterface/distiller": "^1.0.0",
    "@webcontextinterface/bridge": "^1.0.0",
    "@webcontextinterface/context": "^1.0.0"
  },
  "keywords": ["wci", "llm", "agents", "dom", "accessibility", "sdk", "web-context-interface"]
}
