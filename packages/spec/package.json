{
  "name": "@webcontextinterface/spec",
  "version": "1.1.0",
  "description": "WCI specification types and DOM attribute reader",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amirrezaalasti/webcontextinterface.git",
    "directory": "packages/spec"
  },
  "homepage": "https://webcontextinterface.vercel.app/",
  "bugs": {
    "url": "https://github.com/amirrezaalasti/webcontextinterface/issues"
  },
  "keywords": ["wci", "spec", "types", "llm", "agents", "web-context-interface"]
}
