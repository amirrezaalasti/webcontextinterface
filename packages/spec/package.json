{
  "name": "@wci/spec",
  "version": "1.0.0",
  "description": "WCI specification types and DOM attribute reader",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
