{
  "name": "@wci/context",
  "version": "1.0.0",
  "description": "WCI site context — wci.txt, wci.json, wci.md loader and policy engine",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@wci/spec": "*"
  },
  "keywords": ["wci", "wci.txt", "policy", "site-context"]
}
