{
  "wci_version": "1.0",
  "site": {
    "name": "WCI Demo",
    "base_url": ".",
    "purpose": "Interactive showcase and public benchmark for the Web Context Interface (WCI) standard",
    "language": "en",
    "contact": "agents@wci.dev"
  },
  "capabilities": {
    "wci_supported": true,
    "server_side_distil": false,
    "action_protocol_version": "1.0"
  },
  "authentication": {
    "required_for": [],
    "method": "none"
  },
  "task_flows": [
    {
      "id": "try-live-demo",
      "description": "Fill and submit the registration form on the demo home page",
      "steps": [
        { "scope": "registration-form", "url_pattern": "index.html#demo" }
      ]
    },
    {
      "id": "convert-untagged-dom",
      "description": "Paste a DOM snapshot and infer a WCI-like agent view",
      "steps": [
        { "scope": "dom-converter", "url_pattern": "index.html#converter" }
      ]
    },
    {
      "id": "browse-scenarios",
      "description": "Open a benchmark scenario in raw or annotated mode",
      "steps": [
        { "scope": "scenarios-browser", "url_pattern": "scenarios.html" }
      ]
    }
  ],
  "scopes": [
    {
      "id": "registration-form",
      "desc": "Live registration form — email, password, terms, submit",
      "url_pattern": "index.html#demo",
      "key_actions": ["email-input", "password-input", "terms-checkbox", "submit-btn"]
    },
    {
      "id": "dom-converter",
      "desc": "Paste browser DOM HTML and infer an agentic view without data-wci-* tags",
      "url_pattern": "index.html#converter",
      "key_actions": ["parse-dom-btn"]
    },
    {
      "id": "scenarios-browser",
      "desc": "Browse 50 benchmark scenarios — raw HTML vs annotated WCI pages",
      "url_pattern": "scenarios.html",
      "sensitivity": "low"
    }
  ],
  "denied_scopes": ["admin-panel", "internal-debug", "eval-config-raw"],
  "rate_limits": {
    "actions_per_minute": 60,
    "distil_requests_per_minute": 120
  },
  "last_updated": "2026-06-05"
}
